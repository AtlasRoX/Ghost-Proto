{
  "name": "ghostproto",
  "version": "0.2.2",
  "description": "AI-powered codebase auditor — security, quality, performance, architecture & more",
  "keywords": [
    "ghostproto",
    "ai",
    "audit",
    "security",
    "code-quality",
    "static-analysis",
    "cli",
    "code-review",
    "vulnerability",
    "codebase",
    "lint",
    "sast",
    "devsecops"
  ],
  "author": "Shehryar Sohail",
  "license": "MIT",
  "homepage": "https://github.com/AtlasRoX/Ghost-Proto",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AtlasRoX/Ghost-Proto.git"
  },
  "bin": {
    "ghostch": "bin/ghostproto.js",
    "ghostproto": "bin/ghostproto.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "bin/",
    "dist/**/*.js",
    "dist/**/*.d.ts",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/index.ts",
    "typecheck": "tsc --noEmit",
    "pretest": "npm run build",
    "prepare": "npm run build",
    "test": "jest",
    "test:coverage": "npm run build && jest --coverage",
    "prepublishOnly": "npm test"
  },
  "engines": {
    "node": ">=18.0.0"
  },
  "dependencies": {
    "boxen": "^5.1.2",
    "chalk": "^4.1.2",
    "commander": "^12.1.0",
    "fast-glob": "^3.3.2",
    "ignore": "^5.3.2",
    "ora": "^5.4.1",
    "web-tree-sitter": "^0.26.10"
  },
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/node": "^20.14.0",
    "jest": "^30.3.0",
    "ts-jest": "^29.4.6",
    "ts-node": "^10.9.2",
    "typescript": "^5.4.5"
  }
}
